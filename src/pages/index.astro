---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Servicios from "../components/Servicios.astro";
import SobreMi from "../components/SobreMi.astro";
import Contacto from "../components/Contacto.astro";
import { profesional } from "../data/profesional";
---

<Layout title={profesional.titulo}>
    <Navbar />
    <main class="bg-white">
        <Hero />
        <Servicios />
        <SobreMi />
        <Contacto />
    </main>
</Layout>
