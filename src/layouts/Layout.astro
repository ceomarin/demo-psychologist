---
import "../styles/global.css";
import { profesional } from "../data/profesional";

interface Props {
    title?: string;
    description?: string;
}

const { title = profesional.titulo, description = profesional.descripcionSEO } = Astro.props;

const siteUrl = "https://ceomarin.github.io/demo-psychologist";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <!-- SEO básico -->
        <title>{title} | {profesional.nombre}</title>
        <meta name="description" content={description} />

        <!-- Open Graph (WhatsApp, LinkedIn, redes sociales) -->
        <meta property="og:title" content={`${title} | ${profesional.nombre}`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={`${siteUrl}/images/og-image.jpg`} />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="es_CL" />

        <!-- Seguridad -->
        <meta http-equiv="X-Content-Type-Options" content="nosniff" />
        <meta name="referrer" content="strict-origin-when-cross-origin" />

        <!-- Favicon -->
        <link rel="icon" href="/demo-psychologist/public/favicon.svg" />

        <!-- Estilos -->
        <link rel="stylesheet" href="/demo-psychologist/src/styles/global.css" />
    </head>
    <body class="antialiased text-gray-800">
        <slot />
    </body>
</html>
