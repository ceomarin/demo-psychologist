---
import { profesional } from "../data/profesional";
---

<section id="sobre-mi" class="py-24 bg-teal-50">
    <div class="max-w-5xl mx-auto px-6">
        <!-- Encabezado -->
        <div class="text-center mb-14">
            <p class="text-teal-700 font-medium tracking-widest uppercase text-sm mb-3">Sobre mí</p>
            <h2 class="text-4xl font-bold text-gray-800 leading-tight">Conoce a tu psicóloga</h2>
        </div>

        <div class="flex flex-col md:flex-row gap-12 items-start">
            <!-- Foto -->
            <div class="flex-shrink-0 mx-auto md:mx-0">
                <div class="w-56 h-56 rounded-2xl overflow-hidden shadow-lg bg-teal-200">
                    <img src={profesional.foto} alt={`Foto de ${profesional.nombre}`} class="w-full h-full object-cover" onerror="this.style.display='none'" />
                </div>
            </div>

            <!-- Contenido -->
            <div class="flex-1">
                <!-- Bio -->
                <p class="text-gray-600 leading-relaxed text-base mb-8">
                    {profesional.bio}
                </p>

                <!-- Datos clave -->
                <div class="grid grid-cols-1 sm:flex-row gap-4 mb-8">
                    <div class="flex items-center gap-3 text-sm text-gray-600">
                        <span class="w-2 h-2 rounded-full bg-teal-700 flex-shrink-0"></span>
                        <span>{profesional.titulo} — {profesional.universidad}</span>
                    </div>
                    <div class="flex items-center gap-3 text-sm text-gray-600">
                        <span class="w-2 h-2 rounded-full bg-teal-700 flex-shrink-0"></span>
                        <span>Enfoque: {profesional.metodo}</span>
                    </div>
                    <div class="flex items-center gap-3 text-sm text-gray-600">
                        <span class="w-2 h-2 rounded-full bg-teal-700 flex-shrink-0"></span>
                        <span>
                            {profesional.modalidadAtencion === "presencial" && `Atención presencial — ${profesional.direccion}`}
                            {profesional.modalidadAtencion === "online" && "Atención 100% online"}
                            {profesional.modalidadAtencion === "ambas" && `Presencial (${profesional.direccion}) y online`}
                        </span>
                    </div>
                </div>

                <!-- Formación -->
                {
                    profesional.formacion.length > 0 && (
                        <div>
                            <h3 class="text-sm font-semibold text-gray-800 uppercase tracking-widest mb-4">Formación y postitulos</h3>
                            <ul class="flex flex-col gap-3">
                                {profesional.formacion.map((item) => (
                                    <li class="flex items-start gap-3 text-sm text-gray-600">
                                        <svg class="w-5 h-5 text-teal-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        {item}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                }

                <!-- Redes sociales -->
                {
                    (profesional.instagram || profesional.linkedin) && (
                        <div class="flex gap-4 mt-8">
                            {profesional.instagram && (
                                <a href={profesional.instagram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-teal-700 hover:underline">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                                    </svg>
                                    Instagram
                                </a>
                            )}
                            {profesional.linkedin && (
                                <a href={profesional.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-teal-700 hover:underline">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                    </svg>
                                    LinkedIn
                                </a>
                            )}
                        </div>
                    )
                }
            </div>
        </div>
    </div>
</section>
