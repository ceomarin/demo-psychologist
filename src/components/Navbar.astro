---
import { profesional } from "../data/profesional";

const whatsappUrl = `https://wa.me/${profesional.whatsapp}?text=${encodeURIComponent(profesional.whatsappMensaje)}`;
---

<header data-testid="navbar" class="fixed top-0 left-0 w-full bg-white/90 backdrop-blur-sm shadow-sm z-50">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a data-testid="navbar-logo" href="#inicio" class="text-teal-700 font-semibold text-lg tracking-tight">
            {profesional.nombre}
        </a>

        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
            <li><a data-testid="navbar-link-servicios" href="#servicios" class="hover:text-teal-700 transition-colors">Servicios</a></li>
            <li><a data-testid="navbar-link-sobre-mi" href="#sobre-mi" class="hover:text-teal-700 transition-colors">Sobre mí</a></li>
            <li><a data-testid="navbar-link-contacto" href="#contacto" class="hover:text-teal-700 transition-colors">Contacto</a></li>
            <li>
                <a data-testid="navbar-boton-agendar" href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="bg-teal-700 text-white px-4 py-2 rounded-full hover:bg-teal-800 transition-colors">Agendar hora</a>
            </li>
        </ul>

        <button id="menu-toggle" data-testid="navbar-menu-toggle" class="md:hidden text-gray-600 hover:text-teal-700 transition-colors" aria-label="Abrir menú">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </nav>

    <div id="mobile-menu" data-testid="navbar-menu-mobile" class="hidden md:hidden bg-white border-t border-gray-100 px-6 py-4">
        <ul class="flex flex-col gap-4 text-sm font-medium text-gray-600">
            <li><a data-testid="navbar-mobile-link-servicios" href="#servicios" class="hover:text-teal-700 transition-colors">Servicios</a></li>
            <li><a data-testid="navbar-mobile-link-sobre-mi" href="#sobre-mi" class="hover:text-teal-700 transition-colors">Sobre mí</a></li>
            <li><a data-testid="navbar-mobile-link-contacto" href="#contacto" class="hover:text-teal-700 transition-colors">Contacto</a></li>
            <li>
                <a data-testid="navbar-mobile-boton-agendar" href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="block bg-teal-700 text-white px-4 py-2 rounded-full text-center hover:bg-teal-800 transition-colors">Agendar hora</a>
            </li>
        </ul>
    </div>
</header>

<script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });
</script>
